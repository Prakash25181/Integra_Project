<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@+id/cursor_bkgnd"
        android:drawable="@drawable/rc_cursor"/>
    <item>
        <transition>
            <item>
                <color android:color="@color/clear"/>
            </item>
            <item android:drawable="@drawable/rc_cursor_enter"/>
        </transition>
    </item>
    <item>
        <transition>
            <item>
                <color android:color="@color/clear"/>
            </item>
            <item android:drawable="@drawable/rc_cursor_up"/>
        </transition>
    </item>
    <item>
        <transition>
            <item>
                <color android:color="@color/clear"/>
            </item>
            <item android:drawable="@drawable/rc_cursor_down"/>
        </transition>
    </item>
    <item>
        <transition>
            <item>
                <color android:color="@color/clear"/>
            </item>
            <item android:drawable="@drawable/rc_cursor_left"/>
        </transition>
    </item>
    <item>
        <transition>
            <item>
                <color android:color="@color/clear"/>
            </item>
            <item android:drawable="@drawable/rc_cursor_right"/>
        </transition>
    </item>
</layer-list>
