                android:layout_marginLeft="0dp"
                android:layout_marginTop="410dp"
                android:text="5"
                glow_drawable="@drawable/btn_glow50"
                style="@style/RemoteNumberButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="right"
                android:id="@+id/num_6_button"
                android:layout_marginTop="410dp"
                android:layout_marginRight="55dp"
                android:text="6"
                glow_drawable="@drawable/btn_glow50"
                style="@style/RemoteNumberButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="left"
                android:id="@+id/num_7_button"
                android:layout_marginLeft="55dp"
                android:layout_marginTop="454dp"
                android:text="7"
                glow_drawable="@drawable/btn_glow50"
                style="@style/RemoteNumberButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="center_horizontal"
                android:id="@+id/num_8_button"
                android:layout_marginLeft="0dp"
                android:layout_marginTop="454dp"
                android:text="8"
                glow_drawable="@drawable/btn_glow50"
                style="@style/RemoteNumberButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="right"
                android:id="@+id/num_9_button"
                android:layout_marginTop="454dp"
                android:layout_marginRight="55dp"
                android:text="9"
                glow_drawable="@drawable/btn_glow50"
                style="@style/RemoteNumberButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="center_horizontal"
                android:id="@+id/num_0_button"
                android:layout_marginLeft="0dp"
                android:layout_marginTop="498dp"
                android:text="0"
                glow_drawable="@drawable/btn_glow50"
                style="@style/RemoteNumberButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:textSize="12sp"
                android:textColor="@color/rc_button_text"
                android:layout_gravity="right"
                android:id="@+id/clear_button"
                android:background="@drawable/rc_clear"
                android:layout_width="52dp"
                android:layout_height="24dp"
                android:layout_marginTop="508dp"
                android:layout_marginRight="50dp"
                android:text="CLEAR"
                glow_drawable="@drawable/rc_clear_glow"/>
        </FrameLayout>
    </com.onkyo.jp.onkyoremote.view.widget.ScrollViewWidthMaxSize>
</FrameLayout>
