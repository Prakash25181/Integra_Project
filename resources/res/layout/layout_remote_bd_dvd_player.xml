<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="306dp"
    android:layout_height="361dp">
    <com.onkyo.jp.onkyoremote.view.widget.ScrollViewWidthMaxSize
        android:id="@+id/rc_scroll_view"
        android:layout_width="306dp"
        android:layout_height="361dp"
        android:minWidth="306dp"
        android:minHeight="361dp"
        maxHeight="361"
        maxWidth="306">
        <FrameLayout
            android:layout_width="306dp"
            android:layout_height="wrap_content">
            <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
                android:id="@+id/power_button"
                android:background="@drawable/rc_power"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="8dp"
                glow_drawable="@drawable/rc_power_glow"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="top|left"
                android:id="@+id/top_menu_button"
                android:layout_marginLeft="11dp"
                android:layout_marginTop="66dp"
                android:text="TOP MENU"
                glow_drawable="@drawable/rc_button1_glow"
                style="@style/RemoteTextButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="top|left"
                android:id="@+id/setup_button"
                android:layout_marginLeft="11dp"
                android:layout_marginTop="113dp"
                android:text="SETUP"
                glow_drawable="@drawable/rc_button1_glow"
                style="@style/RemoteTextButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="top|right"
                android:id="@+id/display_button"
                android:layout_marginTop="20dp"
                android:layout_marginRight="11dp"
                android:text="DISPLAY"
                glow_drawable="@drawable/rc_button1_glow"
                style="@style/RemoteTextButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="top|right"
                android:id="@+id/menu_button"
                android:layout_marginTop="66dp"
                android:layout_marginRight="11dp"
                android:text="MENU"
                glow_drawable="@drawable/rc_button1_glow"
                style="@style/RemoteTextButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="top|right"
                android:id="@+id/return_button"
                android:layout_marginTop="113dp"
                android:layout_marginRight="11dp"
                android:text="RETURN"
                glow_drawable="@drawable/rc_button1_glow"
                style="@style/RemoteTextButton"/>
            <view
                android:layout_gravity="top|center_horizontal"
                android:id="@+id/cursor_input"
                android:layout_width="144dp"
                android:layout_height="144dp"
                android:layout_marginTop="38dp"
                class="com.onkyo.jp.onkyoremote.view.widget.SwipeCursorView"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
                android:id="@+id/stop_button"
                android:background="@drawable/rc_stop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="42dp"
                android:layout_marginTop="186dp"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
                android:layout_gravity="center_horizontal"
                android:id="@+id/pause_button"
                android:background="@drawable/rc_pause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="186dp"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
                android:layout_gravity="right"
                android:id="@+id/play_button"
                android:background="@drawable/rc_play"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="186dp"
                android:layout_marginRight="42dp"/>
