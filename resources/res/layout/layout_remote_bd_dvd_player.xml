                android:layout_gravity="top|center_horizontal"
                android:id="@+id/color_b_button"
                android:layout_marginTop="319dp"
                android:layout_marginRight="36dp"
                android:text="B"
                style="@style/RemoteColorButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="top|center_horizontal"
                android:id="@+id/color_c_button"
                android:layout_marginLeft="36dp"
                android:layout_marginTop="319dp"
                android:text="C"
                style="@style/RemoteColorButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="top|center_horizontal"
                android:id="@+id/color_d_button"
                android:layout_marginLeft="108dp"
                android:layout_marginTop="319dp"
                android:text="D"
                style="@style/RemoteColorButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="left"
                android:id="@+id/num_1_button"
                android:layout_marginLeft="55dp"
                android:layout_marginTop="366dp"
                android:text="1"
                glow_drawable="@drawable/btn_glow50"
                style="@style/RemoteNumberButton"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="center_horizontal"
                android:id="@+id/num_2_button"
                android:layout_marginLeft="0dp"
                android:layout_marginTop="366dp"
                android:text="2"
