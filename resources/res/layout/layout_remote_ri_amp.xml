<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="306dp"
    android:layout_height="361dp">
    <FrameLayout
        android:layout_width="306dp"
        android:layout_height="wrap_content">
        <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
            android:id="@+id/power_button"
            android:background="@drawable/rc_power"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="8dp"
            glow_drawable="@drawable/rc_power_glow"/>
        <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
            android:layout_gravity="left"
            android:id="@+id/input_up_button"
            android:background="@drawable/rc_input_up"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="93dp"
            android:layout_marginTop="176dp"/>
        <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
            android:layout_gravity="right"
            android:id="@+id/vol_up_button"
            android:background="@drawable/rc_vol_up"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="176dp"
            android:layout_marginRight="93dp"/>
        <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
            android:layout_gravity="left"
            android:id="@+id/input_down_button"
            android:background="@drawable/rc_input_down"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="93dp"
            android:layout_marginTop="247dp"/>
        <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
            android:layout_gravity="right"
            android:id="@+id/volume_down_button"
            android:background="@drawable/rc_vol_down"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="247dp"
            android:layout_marginRight="93dp"/>
        <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
            android:layout_gravity="right"
            android:id="@+id/mute_button"
            android:background="@drawable/rc_mute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="247dp"
            android:layout_marginRight="23dp"/>
        <TextView
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:gravity="center"
            android:layout_gravity="left"
            android:id="@+id/textView5"
            android:layout_width="50dp"
            android:layout_height="21dp"
            android:layout_marginLeft="96dp"
            android:layout_marginTop="300dp"
            android:text="INPUT"
            style="@style/RemoteLabel"/>
        <TextView
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:gravity="center"
            android:layout_gravity="right"
            android:id="@+id/textView6"
            android:layout_width="50dp"
            android:layout_height="21dp"
            android:layout_marginTop="300dp"
            android:layout_marginRight="95dp"
            android:text="VOL"
            style="@style/RemoteLabel"/>
        <TextView
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:gravity="center"
            android:layout_gravity="right"
            android:id="@+id/textView7"
            android:layout_width="50dp"
            android:layout_height="21dp"
            android:layout_marginTop="300dp"
            android:layout_marginRight="25dp"
            android:text="MUTE"
            style="@style/RemoteLabel"/>
    </FrameLayout>
</FrameLayout>
