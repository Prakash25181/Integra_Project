<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/server_select_backgnd"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ListView
            android:id="@+id/deviceList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <Button
            android:textColor="@color/demo_mode_button"
            android:layout_gravity="bottom|right"
            android:id="@+id/demo_mode_button"
            android:background="@color/clear"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginRight="30dp"
            android:text="@string/demoMode"
            android:textAllCaps="false"
            style="?android:attr/borderlessButtonStyle"/>
        <Button
            android:textColor="@color/server_select_other_device_button"
            android:layout_gravity="center_horizontal"
            android:id="@+id/when_not_found_button"
            android:background="@color/clear"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:text="@string/noDeviceButton"
            android:textAllCaps="false"
            style="?android:attr/borderlessButtonStyle"/>
    </LinearLayout>
    <include
        android:id="@+id/connectingProgress"
        android:visibility="gone"
        layout="@layout/layout_connecting_indicator"/>
</FrameLayout>
