<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="306dp"
    android:layout_height="wrap_content">
    <TextView
        android:id="@+id/title_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/toneFront"
        style="@style/AudioSettingsTitle"/>
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_width="274dp"
        android:layout_height="wrap_content">
        <FrameLayout
            android:layout_gravity="center_horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <TextView
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="@color/audio_type"
                android:gravity="center_horizontal"
                android:layout_gravity="top|left"
                android:id="@+id/textView18"
                android:layout_width="20dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="4dp"
                android:text="-"/>
            <TextView
                android:gravity="center_horizontal"
                android:layout_gravity="top|center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/toneBass"
                style="@style/AudioSettingsTitle"/>
            <TextView
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="@color/audio_type"
                android:gravity="center_horizontal"
                android:layout_gravity="top|right"
                android:id="@+id/textView20"
                android:layout_width="20dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="4dp"
                android:text="+"/>
        </FrameLayout>
        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:minWidth="274dp">
            <com.onkyo.jp.onkyoremote.view.widget.StepSlideBar
                android:layout_gravity="center_vertical"
                android:id="@+id/bass_seekbar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                bar_drawable="@drawable/slider_bkgnd"
                thumb_drawable="@drawable/slider_thumb"
                value_drawable="@drawable/slider_value"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
