<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/app_bkgnd"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_gravity="top|center_horizontal"
        android:orientation="vertical"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp">
        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp">
            <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
                android:id="@+id/tuning_down_button"
                android:background="@color/clear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/control_left"/>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="8dp"
                android:layout_weight="1">
                <LinearLayout
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="32dp"
                        android:textColor="@color/ctrl_panel_tuner_freq"
                        android:layout_gravity="bottom"
                        android:id="@+id/freq_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="80.3"/>
                    <TextView
                        android:textSize="16dp"
                        android:textColor="@color/ctrl_panel_tuner_unit"
                        android:layout_gravity="bottom"
                        android:id="@+id/unit_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:text="MHz"/>
                </LinearLayout>
                <Button
                    android:id="@+id/direct_tuning_button"
                    android:background="@color/clear"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    style="?android:attr/borderlessButtonStyle"/>
            </FrameLayout>
            <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
                android:id="@+id/tuning_up_button"
                android:background="@color/clear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/control_right"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/preset_parent_frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
                    android:id="@+id/preset_down_button"
                    android:background="@color/clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/control_left"/>
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"
                    android:layout_weight="1">
                    <LinearLayout
                        android:layout_gravity="center"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.onkyo.jp.onkyoremote.view.widget.AutoScaleTextLabel
                            android:textSize="24dp"
                            android:textColor="@color/ctrl_panel_tuner_no_preset"
                            android:gravity="center"
                            android:id="@+id/preset_name_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No Preset"
                            android:singleLine="true"/>
                    </LinearLayout>
                    <Button
                        android:id="@+id/preset_input_button"
                        android:background="@color/clear"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        style="?android:attr/borderlessButtonStyle"/>
                </FrameLayout>
                <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
                    android:id="@+id/preset_up_button"
                    android:background="@color/clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/control_right"/>
            </LinearLayout>
            <TextView
                android:textSize="16dp"
                android:textColor="@color/ctrl_panel_label"
                android:layout_gravity="center_horizontal"
                android:id="@+id/textView12"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ctrlTunerPreset"/>
            <com.onkyo.jp.onkyoremote.view.widget.GlowButton
                android:layout_gravity="center_horizontal"
                android:id="@+id/memory_button"
                android:layout_marginTop="40dp"
                android:text="@string/ctrlTunerPresetMemory"
                glow_drawable="@drawable/rc_button1_glow"
                style="@style/RemoteTextButton"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
