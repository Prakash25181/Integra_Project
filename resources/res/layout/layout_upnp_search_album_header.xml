<?xml version="1.0" encoding="utf-8"?>
<com.onkyo.jp.onkyoremote.view.controlpage.upnp.NonSelectableCell xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/content_frame"
    android:background="@color/net_cell_bkgnd"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    android:minHeight="50dp">
    <TextView
        android:textSize="16dp"
        android:textColor="@color/net_cell_title"
        android:ellipsize="end"
        android:layout_gravity="center_vertical"
        android:id="@+id/title_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:text="@string/search_AlbumName"
        android:maxLines="1"
        android:minLines="1"
        android:layout_weight="1"/>
</com.onkyo.jp.onkyoremote.view.controlpage.upnp.NonSelectableCell>
