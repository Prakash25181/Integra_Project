<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_root_frame"
    android:background="@color/app_bkgnd"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/bkgnd_main_top"
            android:layout_width="match_parent"
            android:layout_height="64dp">
            <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/sidebar_button"
                android:background="@color/clear"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/sidebar"
                android:contentDescription="Sidebar"/>
            <LinearLayout
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/main_device_name"
                    android:ellipsize="end"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/device_name_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device Name"
                    android:lines="1"/>
                <TextView
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/main_zone_name"
                    android:ellipsize="end"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/zone_name_label"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zone"
                    android:lines="1"/>
            </LinearLayout>
            <com.onkyo.jp.onkyoremote.view.widget.GlowImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/settings_button"
                android:background="@color/clear"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/settings"
                android:contentDescription="Settings"/>
        </LinearLayout>
        <FrameLayout
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@+id/selector_bkgnd_layout"
            android:background="@drawable/bkgnd_input_nrm"
            android:layout_width="match_parent"
            android:layout_height="52dp">
            <ImageView
                android:id="@+id/selector_bkgnd_prs"
                android:background="@drawable/bkgnd_input_prs"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <ImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/back_button"
                android:background="@color/clear"
                android:visibility="invisible"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/back_button"/>
            <Button
                android:textSize="10sp"
                android:textColor="@color/now_playing_button_text"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/now_playing_button"
                android:visibility="invisible"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginRight="-8dp"
                android:text="@string/nowPlaying"
                android:drawableRight="@drawable/playing_button"
                android:contentDescription="Now Playing"
                android:textAllCaps="false"
                android:drawableEnd="@drawable/playing_button"
                style="?android:attr/borderlessButtonStyle"/>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="56dp"
                android:layout_marginRight="56dp"
                android:layout_weight="1">
                <ImageView
                    android:layout_gravity="bottom|center_horizontal"
                    android:id="@+id/selector_down_mark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/down_mark"/>
                <LinearLayout
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:id="@+id/selector_icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginRight="8dp"/>
                    <TextView
                        android:textSize="20sp"
                        android:textColor="@color/main_selector_name"
                        android:layout_gravity="center_vertical"
                        android:id="@+id/selector_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selector"
                        android:singleLine="true"/>
                </LinearLayout>
                <Button
                    android:layout_gravity="top|left"
                    android:id="@+id/selector_button"
                    android:background="@color/clear"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    style="?android:attr/borderlessButtonStyle"/>
            </FrameLayout>
        </FrameLayout>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <FrameLayout
                android:id="@+id/control_page_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <FrameLayout
                android:id="@+id/selector_list_parent"
                android:background="@color/clear"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </FrameLayout>
        <FrameLayout
            android:layout_gravity="bottom"
            android:background="@drawable/bkgnd_toolbar"
            android:layout_width="match_parent"
            android:layout_height="49dp">
            <LinearLayout
                android:layout_gravity="top|center_horizontal"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="49dp">
                <Button
                    android:textSize="12sp"
                    android:textColor="@color/toolbar_button_text"
                    android:gravity="center_horizontal"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/remote_tb_button"
                    android:background="@color/clear"
                    android:layout_width="96dp"
                    android:layout_height="49dp"
                    android:layout_marginRight="2dp"
                    android:text="@string/tb_remote"
                    android:drawableTop="@drawable/toolbar_remote_button"
                    android:contentDescription="Remote Controller"
                    android:textAllCaps="false"
                    style="?android:attr/borderlessButtonStyle"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:background="@color/clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/tb_separator"/>
                <Button
                    android:textSize="12sp"
                    android:textColor="@color/toolbar_button_text"
                    android:gravity="center_horizontal"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/volume_tb_button"
                    android:background="@color/clear"
                    android:layout_width="96dp"
                    android:layout_height="49dp"
                    android:layout_marginLeft="6dp"
                    android:layout_marginRight="6dp"
                    android:text="@string/tb_volume"
                    android:drawableTop="@drawable/toolbar_volume_button"
                    android:contentDescription="Volume"
                    android:textAllCaps="false"
                    style="?android:attr/borderlessButtonStyle"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:background="@color/clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/tb_separator"/>
                <Button
                    android:textSize="12sp"
                    android:textColor="@color/toolbar_button_text"
                    android:gravity="center_horizontal"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/audio_tb_button"
                    android:background="@color/clear"
                    android:layout_width="96dp"
                    android:layout_height="49dp"
                    android:layout_marginLeft="2dp"
                    android:text="@string/tb_audio"
                    android:drawableTop="@drawable/toolbar_audio_button"
                    android:contentDescription="Audio Settings"
                    android:textAllCaps="false"
                    style="?android:attr/borderlessButtonStyle"/>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:id="@+id/zone_popup_frame"
        android:background="@drawable/main_zone_notify_bkgnd"
        android:paddingLeft="20dp"
        android:paddingTop="16dp"
        android:paddingRight="20dp"
        android:paddingBottom="16dp"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="24sp"
            android:textColor="@color/main_zone_name"
            android:layout_gravity="center"
            android:id="@+id/zone_popup_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:id="@+id/volume_value_frame"
        android:background="@drawable/main_volume_value_bkgnd"
        android:paddingLeft="16dp"
        android:paddingTop="10dp"
        android:paddingRight="16dp"
        android:paddingBottom="10dp"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="60dp">
        <TextView
            android:textSize="18sp"
            android:textColor="@color/main_volume_value"
            android:layout_gravity="center"
            android:id="@+id/volume_value_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""/>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/sidebar_parent_frame"
        android:background="@color/sidebar_popup_bkgnd"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <FrameLayout
        android:id="@+id/popup_parent_frame"
        android:background="@color/clear"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <ImageView
        android:layout_gravity="top|center_horizontal"
        android:id="@+id/imageView"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/size"/>
</FrameLayout>
