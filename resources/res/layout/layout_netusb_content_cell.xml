<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/net_cell_bkgnd"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    android:minHeight="50dp">
    <LinearLayout
        android:layout_gravity="bottom|left"
        android:orientation="horizontal"
        android:id="@+id/content_frame"
        android:paddingLeft="16dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/content_icon"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginRight="8dp"/>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="16dp"
                android:textColor="@color/net_cell_title"
                android:ellipsize="end"
                android:layout_gravity="center_vertical"
                android:id="@+id/title_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:minLines="1"
                android:singleLine="true"
                android:layout_weight="1"/>
        </FrameLayout>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/table_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/table_indicator"/>
    </LinearLayout>
    <TextView
        android:textSize="12dp"
        android:textColor="@color/net_loading"
        android:layout_gravity="bottom|right"
        android:id="@+id/loading_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="4dp"
        android:layout_marginBottom="4dp"
        android:text="Loading..."/>
</FrameLayout>
