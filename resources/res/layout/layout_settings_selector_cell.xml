<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/settings_cell_normal"
    android:paddingLeft="8dp"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:minHeight="60dp">
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <CheckBox
            android:layout_gravity="center_vertical"
            android:id="@+id/visible_check"
            android:layout_width="50dp"
            android:layout_height="50dp"/>
        <ImageButton
            android:id="@+id/selector_icon_button"
            android:background="@color/clear"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginRight="4dp"/>
        <com.onkyo.jp.onkyoremote.view.widget.FakeEditText
            android:textSize="16dp"
            android:textColor="@color/settings_cell_data"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical"
            android:id="@+id/edit_text"
            android:layout_width="match_parent"
            android:layout_height="26dp"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="8dp"
            android:lines="1"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/reorder_mark"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="4dp"
            android:layout_marginRight="12dp"
            android:layout_marginBottom="4dp"
            android:src="@drawable/table_reorder_mark"/>
    </LinearLayout>
</FrameLayout>
